# Firebase Admin SDK service account (Project settings → Service accounts → Generate new private key)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Paste the whole private key on one line, keeping the literal \n sequences
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# PostgreSQL database connection
DB_HOST=
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=

# CORS / app
FRONTEND_URL=http://localhost:3000
PORT=3001

# Cloudinary (Dashboard → API Keys)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Optional folder prefix for product images
CLOUDINARY_UPLOAD_FOLDER=wontech/products
